rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }
    function isAdmin() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    function isOwner(sisterId) {
      return isSignedIn() && request.auth.uid == sisterId;
    }

    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow create: if isAdmin() ||
        (isOwner(userId) && request.resource.data.role == 'sister');
      allow update, delete: if isAdmin();
    }

    match /sisters/{sisterId} {
      allow read: if isSignedIn() && (isOwner(sisterId) || isAdmin());
      allow create: if isAdmin() || isOwner(sisterId);
      allow update: if isOwner(sisterId) || isAdmin();
      allow delete: if isAdmin();

      match /{subcollection}/{docId} {
        allow read, write: if isSignedIn() && (isOwner(sisterId) || isAdmin());
      }
    }

    match /{collection}/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}